# ─── Wave Network — Environment Variables ───────────────────────────────────
# Copy this file to .env for local development.
# On Railway: set these in the Railway dashboard → Variables tab.
# NEVER commit your actual .env to git.

# ── Required ────────────────────────────────────────────────────────────────
TOKEN=                        # Your Discord bot token (from Discord Developer Portal)
CLIENT_ID=                    # Your bot's application/client ID

# ── Optional but recommended ────────────────────────────────────────────────
PREFIX=!                      # Legacy prefix (slash commands are primary)
OWNER_IDS=                    # Comma-separated Discord user IDs of bot owners
SERVER_ID=                    # Your support/home guild ID
SUPPORT_URL=                  # Your Discord support server invite link
INVITE_URL=                   # Bot invite link (auto-generated if blank)

# ── Channels ─────────────────────────────────────────────────────────────────
REPORT_CHANNEL_ID=            # Channel for user reports
STATUS_CHANNEL_ID=            # Channel for bot status updates
ERROR_LOG_CHANNEL_ID=         # Channel where critical errors are posted

# ── Access Control ────────────────────────────────────────────────────────────
VIP_ROLE_IDS=                 # Comma-separated role IDs for VIP access
WHITELIST_GUILD_IDS=          # Comma-separated guild IDs (leave blank = all guilds)

# ── Sharding (Railway auto-sets these — usually leave blank) ──────────────────
# SHARD_COUNT=2               # Override auto shard count (comment out for auto)
# HEALTH_PORT=3000            # Port for /health endpoint (Railway sets PORT automatically)

# ── OAuth2 (only needed for web dashboard) ────────────────────────────────────
# USER_SECRET_ID=             # OAuth2 client secret from Discord Developer Portal
# OAUTH_CALLBACK=             # Your Railway domain + /callback  e.g. https://yourapp.railway.app/callback
# DOMAIN=                     # Your Railway public domain  e.g. https://yourapp.railway.app
